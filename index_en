  <style>
    
/* === MOBILE – wyłączamy przyciemnianie na telefonach === */
@media (max-width: 768px) {
  .process-photo-img,
  .gallery-photo-img,
  .gallery-hover {
    filter: brightness(1) !important;   /* zawsze pełne jasne na telefonie */
  }
}

/* === EFEKT PRZYCIEMNIENIA – Warsztat + Galeria === */
.process-photo-img,
.gallery-photo-img,
.gallery-hover {
  filter: brightness(0.8);           /* 20% przyciemnione na start */
  transition: filter 0.3s ease-in-out; /* piękne, płynne przejście */
}

.process-photo-img:hover,
.gallery-photo-img:hover,
.gallery-hover:hover {
  filter: brightness(1);             /* pełne rozświetlenie */
}


    /* LIGHTBOX */
.modal {
  display: none;
  position: fixed;
  z-index: 9999;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.95);
  overflow: auto;
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  max-width: 95%;
  max-height: 95%;
  object-fit: contain;
  box-shadow: 0 0 30px rgba(0,0,0,0.8);
}

.close {
  position: absolute;
  top: 25px;
  right: 35px;
  color: #fff;
  font-size: 50px;
  font-weight: bold;
  cursor: pointer;
  z-index: 10000;
  line-height: 1;
}

.close:hover {
  color: #ffcc00;
}

    :root {
      --anthracite: #1F1F1F;
      --copper: #D9773F;
      --copper-light: #E8935A;
      --copper-dark: #B85F2A;
      --white: #F5F0EB;
      --gray-mid: #2E2E2E;
      --gray-light: #3A3A3A;
      --text-muted: #9A9A9A;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background-color: var(--anthracite);
      color: var(--white);
      font-family: 'Montserrat', sans-serif;
      overflow-x: hidden;
      scroll-behavior: smooth;
    }

    .site-wrapper {
      width: 100%;
      min-height: 100%;
      overflow-y: auto;
      overflow-x: hidden;
    }

    /* ── Typography ── */
    .font-cinzel { font-family: 'Cinzel', serif; }
    .font-playfair { font-family: 'Playfair Display', serif; }
    .font-montserrat { font-family: 'Montserrat', sans-serif; }

    /* ── Copper accent ── */
    .text-copper { color: var(--copper); }
    .bg-copper { background-color: var(--copper); }
    .border-copper { border-color: var(--copper); }

    /* ── Hero ── */
#hero {
      position: relative;
      width: 100%;
      min-height: 100vh;
      max-height: 950px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background-color: #0a0a0a;
    }

    @media (max-width: 768px) {
      #hero {
        min-height: 90vh;
        padding-top: 80px;
      }
      .hero-title {
        font-size: clamp(2.5rem, 8.5vw, 5rem) !important;
      }
    }


    .hero-photo-placeholder {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: none; 
      border: none;
    }

    .hero-photo-label {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: rgba(0,0,0,0.75);
      border: 1px dashed var(--copper);
      color: var(--copper);
      font-family: 'Montserrat', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 1rem 2rem;
      text-align: center;
      pointer-events: none;
      white-space: nowrap;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(10,10,10,0.2) 0%, rgba(10,10,10,0.55) 70%, rgba(10,10,10,0.92) 100%);
    }

    .hero-content {
      position: relative;
      z-index: 10;
      text-align: center;
      padding: 0 1.5rem;
    }

    .hero-eyebrow {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--copper);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
    }

    .hero-eyebrow::before,
    .hero-eyebrow::after {
      content: '';
      display: block;
      width: 40px;
      height: 1px;
      background: var(--copper);
      opacity: 0.7;
    }

    .hero-title {
      font-family: 'Cinzel', serif;
      font-size: clamp(2.8rem, 7vw, 6.5rem);
      font-weight: 700;
      color: var(--white);
      letter-spacing: 0.05em;
      line-height: 1.05;
      text-shadow: 0 4px 40px rgba(217,119,63,0.3), 0 2px 8px rgba(0,0,0,0.8);
      margin-bottom: 1.5rem;
    }

    .hero-subtitle {
      font-family: 'Montserrat', sans-serif;
      font-size: clamp(0.85rem, 1.8vw, 1.1rem);
      font-weight: 300;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(245,240,235,0.75);
    }

    .hero-scroll-hint {
      position: absolute;
      bottom: 2.5rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      opacity: 0.6;
    }

    .scroll-line {
      width: 1px;
      height: 50px;
      background: linear-gradient(to bottom, var(--copper), transparent);
      animation: scroll-drop 1.8s ease-in-out infinite;
    }

    @keyframes scroll-drop {
      0% { transform: scaleY(0); transform-origin: top; opacity: 1; }
      50% { transform: scaleY(1); transform-origin: top; opacity: 1; }
      100% { transform: scaleY(1); transform-origin: bottom; opacity: 0; }
    }

    /* ── Industrial Divider ── */
    .pipe-divider {
      display: flex;
      align-items: center;
      gap: 0;
      margin: 0 auto;
      width: 100%;
      max-width: 800px;
    }

    .pipe-line {
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, transparent, var(--copper), transparent);
      opacity: 0.4;
    }

    .pipe-rivet {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--copper);
      opacity: 0.7;
      margin: 0 6px;
      box-shadow: 0 0 6px rgba(217,119,63,0.5);
    }

    .pipe-connector {
      width: 18px;
      height: 6px;
      border: 1px solid var(--copper);
      opacity: 0.5;
      border-radius: 1px;
      margin: 0 4px;
    }

/* ── Section base ── */
    .section-pad {
      padding: 7rem 1.5rem;
    }

    @media (max-width: 768px) {
      .section-pad {
        padding: 4.5rem 1rem;
      }
    }

    .section-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1rem;
    }

    .section-label {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--copper);
      margin-bottom: 1.2rem;
      display: flex;
      align-items: center;
      gap: 0.8rem;
    }

    .section-label::after {
      content: '';
      display: block;
      width: 30px;
      height: 1px;
      background: var(--copper);
      opacity: 0.6;
    }

    .section-title {
      font-family: 'Cinzel', serif;
      font-size: clamp(1.6rem, 3.5vw, 2.8rem);
      font-weight: 600;
      color: var(--white);
      line-height: 1.2;
      margin-bottom: 2.5rem;
    }

    .section-title span { color: var(--copper); }

    /* ── Section 2: About ── */
    #about {
      background: linear-gradient(160deg, #1F1F1F 0%, #191409 60%, #1F1F1F 100%);
    }

    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }

    @media (max-width: 768px) {
      .about-grid { grid-template-columns: 1fr; gap: 3rem; }
    }

    .about-text p {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.95rem;
      line-height: 1.9;
      color: rgba(245,240,235,0.78);
      margin-bottom: 1.4rem;
    }

    .about-text .highlight-line {
      color: var(--white);
      font-weight: 500;
      border-left: 3px solid var(--copper);
      padding-left: 1rem;
      margin: 1.5rem 0;
      font-style: italic;
      opacity: 0.95;
    }

    .bullet-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      margin: 0.6rem 0;
      font-size: 0.88rem;
      color: rgba(245,240,235,0.8);
      line-height: 1.6;
    }

    .bullet-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--copper);
      margin-top: 0.55rem;
      flex-shrink: 0;
    }

    /* ==================== GRIDS ==================== */
    
    /* Grid dla 4 zdjęć w sekcji Rzemiosło (2x2) */
    .process-photos {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.4rem;
      margin-bottom: 3.5rem;           /* <-- dodane */
    }

    /* Grid dla galerii lamp (Oferta) */
    .lamp-photos-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-bottom: 4rem;             /* <-- to jest najważniejsze */
    }

    /* Desktop - sztywno 3 kolumny dla galerii */
    @media (min-width: 1024px) {
      .lamp-photos-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    /* Tablet */
    @media (max-width: 768px) {
      .process-photos {
        grid-template-columns: repeat(2, 1fr);
      }
      
      .lamp-photos-grid {
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        margin-bottom: 3.5rem;
      }
    }

    /* Telefon */
    @media (max-width: 640px) {
      .process-photos,
      .lamp-photos-grid {
        grid-template-columns: 1fr;
        margin-bottom: 3rem;
      }
    }
    .process-photo-slot {
      aspect-ratio: 1;
      background: var(--gray-mid);
      border: 1px dashed rgba(217,119,63,0.35);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      position: relative;
      overflow: hidden;
      cursor: pointer;
      transition: border-color 0.3s;
    }

    .process-photo-slot:hover { border-color: var(--copper); }

    .process-photo-slot .photo-label {
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--copper);
      opacity: 0.7;
      text-align: center;
      padding: 0 0.5rem;
    }

    .process-photo-slot .photo-icon {
      color: var(--copper);
      opacity: 0.4;
    }

    /* ── Section 3: Offer ── */
    #offer {
      background-color: var(--anthracite);
    }

@media (max-width: 640px) {
      .process-photos,
      .lamp-photos-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .lamp-photos-grid { grid-template-columns: 1fr; }
    }

    .lamp-photo-slot {
      aspect-ratio: 4/3;
      background: linear-gradient(135deg, #242424, #1a1a1a);
      border: 1px dashed rgba(217,119,63,0.3);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      position: relative;
      overflow: hidden;
      transition: border-color 0.3s;
    }

    .lamp-photo-slot:hover { border-color: rgba(217,119,63,0.7); }

    .lamp-photo-slot .slot-label {
      font-size: 0.62rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--copper);
      opacity: 0.65;
      text-align: center;
      padding: 0 1rem;
    }

    .lamp-photo-slot .slot-num {
      font-family: 'Cinzel', serif;
      font-size: 1.8rem;
      color: rgba(217,119,63,0.15);
      font-weight: 700;
      position: absolute;
      top: 0.8rem;
      left: 1rem;
    }

    .product-card {
      background: var(--gray-mid);
      border: 1px solid rgba(217,119,63,0.2);
      padding: 2.5rem 3rem;
      position: relative;
      overflow: hidden;
    }

    .product-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 4px;
      height: 100%;
      background: linear-gradient(to bottom, var(--copper), var(--copper-dark));
    }

    @media (max-width: 640px) {
      .product-card { padding: 2rem 1.5rem 2rem 2rem; }
    }

    .product-title {
      font-family: 'Cinzel', serif;
      font-size: clamp(1.1rem, 2.5vw, 1.5rem);
      font-weight: 600;
      color: var(--white);
      margin-bottom: 0.5rem;
    }

    .product-subtitle {
      font-size: 0.8rem;
      color: var(--copper);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 1.8rem;
      font-weight: 500;
    }

    .product-specs {
      list-style: none;
      margin-bottom: 2rem;
    }

    .product-specs li {
      display: flex;
      align-items: flex-start;
      gap: 0.7rem;
      padding: 0.45rem 0;
      font-size: 0.87rem;
      color: rgba(245,240,235,0.8);
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }

    .product-specs li .spec-dot {
      color: var(--copper);
      margin-top: 0.1rem;
      flex-shrink: 0;
    }

    .price-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      background: linear-gradient(135deg, var(--copper), var(--copper-dark));
      padding: 0.75rem 2rem;
      margin-bottom: 1.5rem;
    }

    .price-text {
      font-family: 'Cinzel', serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: white;
      letter-spacing: 0.05em;
    }

    .delivery-info {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.7;
    }

    .delivery-info span { color: rgba(245,240,235,0.6); }

    .certifications {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(255,255,255,0.06);
    }

    .cert-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .cert-item i { color: var(--copper); }

    /* ── Section 4: Buy Now ── */
    #buy {
      background: linear-gradient(160deg, #191409 0%, #1F1F1F 50%, #191409 100%);
      text-align: center;
    }

    .buy-title {
      font-family: 'Cinzel', serif;
      font-size: clamp(1.8rem, 4vw, 3.2rem);
      font-weight: 700;
      color: var(--white);
      margin-bottom: 0.8rem;
    }

    .buy-subtitle {
      font-size: 0.88rem;
      color: var(--text-muted);
      letter-spacing: 0.2em;
      text-transform: uppercase;
      margin-bottom: 3.5rem;
    }

    .buy-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
      margin-bottom: 2rem;
    }

    .buy-btn {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: transparent;
      border: 2px solid var(--copper);
      color: var(--white);
      font-family: 'Montserrat', sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 1.1rem 2.2rem;
      cursor: pointer;
      transition: all 0.25s ease;
      text-decoration: none;
      position: relative;
      overflow: hidden;
    }

    .buy-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--copper);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.25s ease;
      z-index: 0;
    }

    .buy-btn:hover::before { transform: scaleX(1); }
    .buy-btn:hover { color: white; }
    .buy-btn > * { position: relative; z-index: 1; }

    .buy-btn.primary {
      background: var(--copper);
      color: white;
    }

    .buy-btn.primary::before { background: var(--copper-light); }

    .pickup-note {
      font-size: 0.8rem;
      color: var(--text-muted);
      letter-spacing: 0.1em;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .pickup-note i { color: var(--copper); }

    /* ── Section 5: Footer ── */
    #contact {
      background: #141414;
      padding: 5rem 1.5rem 3rem;
      border-top: 1px solid rgba(217,119,63,0.2);
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 3rem;
      max-width: 1000px;
      margin: 0 auto 4rem;
    }

    @media (max-width: 768px) {
      .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
    }

 .contact-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  justify-content: center !important;
}

    .contact-icon-wrap {
      width: 44px;
      height: 44px;
      border: 1px solid rgba(217,119,63,0.4);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .contact-icon-wrap i { color: var(--copper); }

    .contact-label {
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 0.3rem;
    }

    .contact-value {
      font-size: 0.9rem;
      color: var(--white);
      font-weight: 500;
    }

    .footer-bottom {
      text-align: center;
      padding-top: 2.5rem;
      border-top: 1px solid rgba(255,255,255,0.05);
    }

    .footer-logo {
      font-family: 'Cinzel', serif;
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--copper);
      letter-spacing: 0.15em;
      margin-bottom: 1rem;
    }

    .footer-copy {
      font-size: 0.75rem;
      color: var(--text-muted);
      letter-spacing: 0.1em;
    }

    /* ── Animations on scroll ── */
    .fade-up {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }

    .fade-up.visible {
      opacity: 1;
      transform: translateY(0);
    }

/* ── NAV BAR ── */
#navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 1rem 1.25rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(0,0,0,0.15);
  transition: all 0.4s ease;
  flex-wrap: wrap;
  gap: 0.8rem;
}

#navbar.scrolled {
  background: rgba(20, 14, 6, 0.95);
  backdrop-filter: blur(12px);
  box-shadow: 0 4px 20px rgba(0,0,0,0.6);
}

.nav-logo {
  font-family: 'Cinzel', serif;
  font-size: 1.75rem;
  font-weight: 700;
  color: var(--copper);
  letter-spacing: 0.08em;
  white-space: nowrap;
}

.nav-links {
  display: flex;
  gap: 1.8rem;
  list-style: none;
  margin: 0;
  padding: 0;
  flex-wrap: wrap;
  justify-content: center;
}

.nav-links a {
  font-size: 1.05rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(245,240,235,0.85);
  text-decoration: none;
  transition: color 0.2s;
  white-space: nowrap;
}

.nav-links a:hover { 
  color: var(--copper); 
}

/* Mobile */
@media (max-width: 768px) {
  #navbar {
    padding: 1rem 1rem 0.8rem;
    flex-direction: column;
    gap: 0.9rem;
  }
  
  .nav-logo {
    font-size: 1.55rem;
  }
  
  .nav-links {
    gap: 1.4rem;
    width: 100%;
    justify-content: center;
  }
  
  .nav-links a {
    font-size: 0.97rem;
  }
}


